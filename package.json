{
  "name": "blender-batch-render",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently --kill-others -n server,web -c cyan,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:kill": "taskkill /F /FI \"WINDOWTITLE eq uvicorn\" 2>nul; taskkill /F /FI \"WINDOWTITLE eq vite\" 2>nul",
    "dev:sh": "bash scripts/dev.sh",
    "dev:bat": "scripts\\dev.bat",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "python -m uvicorn server.main:app --reload --host 127.0.0.1 --port 34567"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
